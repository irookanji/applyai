{
  "name": "applyai",
  "private": true,
  "type": "module",
  "author": "@irookanji",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test apps packages",
    "test:watch": "bun test --watch apps packages",
    "test:shared": "bun run --filter @applyai/shared test",
    "test:api": "bun run --filter @applyai/api test",
    "test:web": "bun run --filter @applyai/web test",
    "dev": "docker compose stop api web 2>/dev/null || true; bun run --filter @applyai/api dev & bun run --filter @applyai/web dev",
    "dev:api": "docker compose stop api 2>/dev/null || true; bun run --filter @applyai/api dev",
    "dev:web": "docker compose stop web 2>/dev/null || true; bun run --filter @applyai/web dev",
    "build": "bun run --filter @applyai/web build",
    "ci": "bun run lint && bun test apps packages && bun run build && bun run knip",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "knip": "knip",
    "db:up": "docker compose up -d postgres",
    "docker:stop-app": "docker compose stop api web",
    "db:generate": "bun run --filter @applyai/db generate",
    "db:migrate": "bun run --filter @applyai/db migrate",
    "db:studio": "bun run --filter @applyai/db studio",
    "start": "./start.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "knip": "6.18.0",
    "lint-staged": "17.0.8"
  }
}
